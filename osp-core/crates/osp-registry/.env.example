# OSP Registry Server Configuration

# HTTP port to listen on
PORT=8080

# SQLite database path (prefix with sqlite:// for consistency)
DATABASE_URL=sqlite:///data/registry.db

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# Admin key for privileged operations (e.g. DELETE manifests)
# Generate with: openssl rand -hex 32
OSP_REGISTRY_ADMIN_KEY=
