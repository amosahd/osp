      "credentials_schema": {
        "type": "object",
        "required": ["connection_string", "host", "port", "database", "username", "password"],
        "properties": {
          "connection_string": {
            "type": "string",
            "description": "Full PostgreSQL connection string with pooler"
          },
          "host": {
            "type": "string",
            "description": "Database host (e.g., ep-cool-darkness-123456.us-east-2.aws.neon.tech)"
          },
          "port": {
            "type": "integer",
            "description": "Database port (default: 5432)"
          },
          "database": {
            "type": "string",
            "description": "Database name"
          },
          "username": {
            "type": "string",
            "description": "Database username"
          },
          "password": {
            "type": "string",
            "description": "Database password"
          },
          "pooler_connection_string": {
            "type": "string",
            "description": "Connection string via connection pooler for serverless environments"
          },
          "branch_id": {
            "type": "string",
